FLASK_ENV=development
# 5000 is commonly taken by other local projects — this app defaults to 5057.
PORT=5057
SECRET_KEY=change-this-to-a-long-random-value
JWT_SECRET_KEY=change-this-to-a-different-long-random-value

DATABASE_URL=postgresql+psycopg2://eventsphere:eventsphere@localhost:5432/eventsphere

FRONTEND_ORIGIN=http://localhost:5173

# Used only by seed.py to create the first admin account
ADMIN_NAME=Platform Admin
ADMIN_EMAIL=admin@eventspherepro.test
ADMIN_PASSWORD=ChangeMe123!
